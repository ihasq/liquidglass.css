{
  "name": "liquidglass.css",
  "version": "0.0.24",
  "description": "Physics-based liquid glass refraction effect using CSS and SVG filters",
  "type": "module",
  "main": "dist/liquidglass.js",
  "module": "dist/liquidglass.js",
  "types": "dist/liquidglass.d.ts",
  "exports": {
    ".": {
      "types": "./dist/liquidglass.d.ts",
      "import": "./dist/liquidglass.js",
      "default": "./dist/liquidglass.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js",
      "default": "./dist/tailwind.js"
    },
    "./stylex": {
      "types": "./dist/ports/stylex.d.ts",
      "import": "./dist/stylex.js",
      "default": "./dist/stylex.js"
    },
    "./emotion": {
      "types": "./dist/ports/emotion.d.ts",
      "import": "./dist/emotion.js",
      "default": "./dist/emotion.js"
    },
    "./styled-components": {
      "types": "./dist/ports/styled-components.d.ts",
      "import": "./dist/styled-components.js",
      "default": "./dist/styled-components.js"
    },
    "./vanilla-extract": {
      "types": "./dist/ports/vanilla-extract.d.ts",
      "import": "./dist/vanilla-extract.js",
      "default": "./dist/vanilla-extract.js"
    },
    "./panda": {
      "types": "./dist/ports/panda.d.ts",
      "import": "./dist/panda.js",
      "default": "./dist/panda.js"
    },
    "./unocss": {
      "types": "./dist/ports/unocss.d.ts",
      "import": "./dist/unocss.js",
      "default": "./dist/unocss.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js",
      "default": "./dist/env.js"
    }
  },
  "workspaces": [
    "site"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-displacement-luts.mjs",
    "build": "tsc && vite build",
    "generate-luts": "node scripts/generate-displacement-luts.mjs",
    "build:site": "npm run build && npm run build -w site",
    "preview": "vite preview",
    "test": "node test/integrity/index.mjs",
    "test:types": "node test/integrity/index.mjs --only=types",
    "test:build": "node test/integrity/index.mjs --only=build",
    "test:smt": "node test/integrity/index.mjs --only=smt",
    "test:ssr": "npm run build && node test/integrity/ssr-import.mjs",
    "test:perf": "node test/perf/render-budget.mjs",
    "test:e2e": "npx serve test -l 3333 --no-clipboard",
    "test:e2e:headed": "node test/e2e/runner.mjs --headed",
    "test:e2e:verbose": "node test/e2e/runner.mjs --verbose",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "asbuild:debug": "asc src/shaders/wasm/index.ts --target debug",
    "asbuild:release": "asc src/shaders/wasm/index.ts --target release",
    "start": "npx serve ."
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@webgpu/types": "^0.1.69",
    "assemblyscript": "^0.28.14",
    "preact": "^10.29.1",
    "puppeteer": "^22.15.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.0",
    "vite-plugin-glsl": "^1.6.0",
    "z3-solver": "^4.16.0"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "keywords": [
    "liquid-glass",
    "glass-effect",
    "refraction",
    "svg-filter",
    "backdrop-filter",
    "css"
  ],
  "license": "MIT"
}
